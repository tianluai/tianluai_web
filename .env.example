# Next.js app — copy to `.env.local` (recommended) or `.env` (see `.gitignore`: `.env` is ignored).

NODE_ENV=development

# --- NextAuth (Google sign-in) ---
# Required. Generate: `openssl rand -base64 32`
AUTH_SECRET=
# Same Google OAuth **Web** client as the API Drive integration is fine; add both redirect URIs in Google Cloud Console:
# - http://localhost:3000/api/auth/callback/google   (NextAuth)
# - http://localhost:3001/drive/callback             (Nest Drive), if you use the same client
# Optional: `AUTH_URL=https://your-production-host` in prod.
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Required; must match Nest `AUTH_JWT_SECRET` (HS256 Bearer for the API).
AUTH_JWT_SECRET=

NEXT_PUBLIC_API_URL=http://localhost:3001

# Sentry (optional — must be NEXT_PUBLIC_* for browser SDK)
NEXT_PUBLIC_SENTRY_DSN=

# --- Clerk (paused — keep keys here if you re-enable Clerk) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# NEXT_PUBLIC_CLERK_PROXY_URL=
# CLERK_SECRET_KEY=

# Optional: source map upload in CI (see next.config.ts)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
