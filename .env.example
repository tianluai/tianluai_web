# Next.js app — copy to .env.local (recommended) or .env

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# When Clerk Dashboard uses a custom Frontend API domain (e.g. clerk.example.com), set this to https://clerk.example.com
# NEXT_PUBLIC_CLERK_FAPI=
CLERK_SECRET_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001

# Sentry (optional — must be NEXT_PUBLIC_* for browser SDK; leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=

# Optional: source map upload in CI (see next.config.ts)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
